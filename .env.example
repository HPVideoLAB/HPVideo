# HPVideo environment variables template
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hpvideo_dp
# Use postgres+pool:// prefix in DATABASE_URL to enable connection pooling
# e.g. DATABASE_URL=postgres+pool://postgres:pw@postgres:5432/hpvideo_dp
DATABASE_URL=postgres+pool://postgres:CHANGE_ME@postgres:5432/hpvideo_dp
DB_MAX_CONNECTIONS=20
DB_STALE_TIMEOUT=300

# === Redis (if used) ===
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === JWT / Auth ===
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
WEBUI_AUTH=true
JWT_EXPIRES_IN=24h

# === CORS (comma-separated list of allowed origins) ===
CORS_ALLOWED_ORIGINS=https://hpvideo.io,https://app.hpvideo.io

# === Blockchain RPCs ===
BNB_RPC=https://bsc-dataseed.binance.org/
DBC_RPC=https://rpc1.dbcwallet.io
DLCP_RECEIVE_ADDRESS=0xeAc67D1B54730FF65D322aA21F2C3c8A8202Be0C

# === AI Services ===
OPENAI_API_KEY=
ALIYUN_API_KEY=

# === Storage ===
ALI_OSS_ACCESS_KEY=
ALI_OSS_SECRET_KEY=
ALI_OSS_BUCKET=
